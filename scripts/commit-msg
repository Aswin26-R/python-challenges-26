#!/bin/sh
# Git commit-msg hook — validates commit message format
# Installed by: cp scripts/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

MSG=$(cat "$1" | head -1 | xargs)
LOWER=$(echo "$MSG" | tr '[:upper:]' '[:lower:]')

# Rule 1: minimum 15 characters
if [ ${#MSG} -lt 15 ]; then
  echo ""
  echo "❌ Commit rejected: message too short (${#MSG} chars, need at least 15)."
  echo "   Your message: '$MSG'"
  echo ""
  echo "Good examples:"
  echo "  Complete challenge 01: hello world"
  echo "  Fix: address review feedback"
  echo "  Fix failing test in challenge 03"
  echo ""
  exit 1
fi

# Rule 2: block lazy messages
case "$LOWER" in
  done|stuff|aaa|bbb|wip|test|fix|update|changes|misc|asdf|ok|temp|edit|work|progress|commit|added|modified)
    echo ""
    echo "❌ Commit rejected: message '$MSG' is too vague."
    echo ""
    echo "Good examples:"
    echo "  Complete challenge 01: hello world"
    echo "  Fix: address review feedback"
    echo "  Fix failing test in challenge 03"
    echo ""
    exit 1
    ;;
esac

exit 0
